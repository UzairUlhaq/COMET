{
  "name": "lnpdb_heartkidney",
  "run_dir": "experiments",
  "data": {
    "raw_csv": "experiments/data_raw/LNPDB.csv",
    "json": "experiments/data_json/LNPDB_heart_kidney.json",
    "processed_root": "experiments/processed_data_dirs/lnpdb_heartkidney_gen",
    "dataset_name": "lnpdb",
    "target_labels": ["heart", "kidney"],
    "kfold_valid": 5,
    "test_ratio": 0.2,
    "nthreads": 8
  },
  "schema": "experiments/task_schemas/lnpdb_heart_kidney_schema.json",
  "training": {
    "fold": 0,
    "seed": 1,
    "epochs": 30,
    "batch_size": 8,
    "eval_batch_size": 8,
    "lr": 0.0001,
    "warmup_ratio": 0.06,
    "dropout": 0.1,
    "loss": "np_finetune_contrastive",
    "metric": "valid_spearmanr_coeff",
    "patience": 20,
    "cagrad_c": 0,
    "percent_noise": 0.1,
    "percent_noise_type": "normal_proportionate",
    "contrast_margin_coeff": 0.01,
    "train_data_ratio": 1,
    "required_batch_size_multiple": 1,
    "num_workers": 0,
    "freeze_molecule_encoder": true,
    "finetune_from_model": "ckp/mol_pre_no_h_220816.pt",
    "dict_name": "dict.txt",
    "only_polar": 0,
    "conf_size": 11,
    "lnp_encoder_layers": 8,
    "lnp_encoder_embed_dim": 256,
    "lnp_encoder_ffn_embed_dim": 256,
    "lnp_encoder_attention_heads": 8,
    "save_root": "experiments/save_lnpdb_heartkidney",
    "tmp_save_root": "experiments/tmp_save_lnpdb_heartkidney",
    "log_root": "experiments/logs/tmp",
    "infer_root": "experiments/infer_results",
    "run_inference_after_train": true,
    "fp16": true
  }
}
